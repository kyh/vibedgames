{
  "name": "@repo/party",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir=dist",
    "clean": "rm -rf .cache .turbo .wrangler dist node_modules",
    "deploy": "wrangler deploy --name vibedgames-party",
    "dev": "pnpm with-env wrangler dev",
    "test": "node --import tsx --test test/integration.test.ts",
    "typecheck": "tsc --noEmit && tsc -p test --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@repo/api": "workspace:^",
    "@repo/db": "workspace:^",
    "@vibedgames/multiplayer": "workspace:^"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@kyh/tsconfig": "catalog:",
    "@types/node": "catalog:",
    "partyserver": "^0.5.8",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  }
}
