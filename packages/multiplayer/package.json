{
  "name": "@vibedgames/multiplayer",
  "version": "0.0.2",
  "description": "Multiplayer for browser games — framework-agnostic core + React hooks",
  "private": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./react": "./src/react.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./react": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf .cache .turbo dist node_modules",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "partysocket": "^1.1.16"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@kyh/tsconfig": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:"
  },
  "keywords": [
    "multiplayer",
    "react",
    "hooks",
    "gamedev",
    "websocket",
    "partykit"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kyh/vibedgames",
    "directory": "packages/multiplayer"
  }
}
