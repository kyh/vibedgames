# Cloudflare D1 (set via wrangler.jsonc binding for runtime; these are for drizzle-kit)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_DATABASE_ID=""
CLOUDFLARE_D1_TOKEN=""
CLOUDFLARE_API_TOKEN=""

# better-auth
AUTH_SECRET=""
PRODUCTION_URL="https://vibedgames.com"

# R2 (for presigning game deploys via the S3 API)
R2_ACCOUNT_ID=""
R2_BUCKET_NAME="vibedgames-games"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# fal.ai (powers `vg generate`). Optional at boot; a missing key just means
# media procedures error until configured. Optional base-URL overrides let
# you front each fal target (queue/platform/storage/docs) through a
# Cloudflare AI Gateway prefix.
FAL_API_KEY=""
# FAL_QUEUE_BASE_URL=""
# FAL_PLATFORM_BASE_URL=""
# FAL_STORAGE_BASE_URL=""
# FAL_DOCS_BASE_URL=""
