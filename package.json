{
  "name": "vibedgames",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "rm -rf .turbo node_modules",
    "clean:workspaces": "turbo run clean",
    "deploy:games": "turbo run build --filter=./games/* --filter=vibedgames && for d in games/*/; do node apps/cli/dist/index.js deploy \"$d\" || exit 1; done",
    "db:push": "pnpm -F db push",
    "db:push-remote": "pnpm -F db push:remote && pnpm -F builder push:remote",
    "db:push-local": "pnpm -F db push:local",
    "db:seed-local": "pnpm -C apps/web exec wrangler d1 execute vibedgames --local --file=../../packages/db/seed.sql",
    "db:local": "pnpm db:push-local && pnpm db:seed-local",
    "admin:create": "tsx scripts/create-admin.ts",
    "dogfood": "tsx scripts/dogfood.ts",
    "dogfood:reset": "tsx scripts/dogfood-reset.ts",
    "dev": "turbo watch db studio dev --continue --filter=!./games/*",
    "dev:web": "turbo watch dev -F @repo/web...",
    "dev:party": "turbo watch dev -F @repo/party...",
    "dev:games": "turbo watch dev -F @repo/games...",
    "dev:flappy-dragons": "turbo watch dev -F @repo/flappy-dragons...",
    "dev:pacman": "turbo watch dev -F @repo/pacman...",
    "dev:tetris": "turbo watch dev -F @repo/tetris...",
    "dev:starfall": "turbo watch dev -F @repo/starfall...",
    "dev:pong": "turbo watch dev -F @repo/pong...",
    "dev:bomberman": "turbo watch dev -F @repo/bomberman...",
    "dev:farm": "turbo watch dev -F @repo/farm...",
    "dev:moba": "turbo watch dev -F @repo/moba...",
    "dev:crazy-waymo": "turbo watch dev -F @repo/crazy-waymo...",
    "dev:battle-arena": "turbo watch dev -F @repo/battle-arena...",
    "dev:lunerfall": "turbo watch dev -F @repo/lunerfall...",
    "dev:cli": "turbo watch dev -F vibedgames...",
    "lint": "oxlint --report-unused-disable-directives",
    "r2:lifecycle": "pnpm -C apps/web exec wrangler r2 bucket lifecycle set vibedgames-games --file ./infra/r2/vibedgames-games.lifecycle.json --force",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "oxfmt",
    "lint:fix": "oxlint --fix",
    "format:fix": "oxfmt --write"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsx": "^4.23.0",
    "turbo": "^2.10.4",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "@tailwindcss/oxide",
      "core-js",
      "esbuild",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "react-hook-form": "^7.72.1"
    }
  }
}
