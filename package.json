{
  "name": "vibedgames",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "rm -rf .turbo node_modules",
    "clean:workspaces": "turbo run clean",
    "db:push": "pnpm -F db push",
    "db:push-remote": "pnpm -F db push:remote && pnpm -F builder push:remote",
    "admin:create": "tsx scripts/create-admin.ts",
    "dev": "turbo watch db studio dev --continue --filter=!./games/*",
    "dev:web": "turbo watch dev -F @repo/web...",
    "dev:party": "turbo watch dev -F @repo/party...",
    "dev:games": "turbo watch dev -F @repo/games...",
    "dev:flappy-bird": "turbo watch dev -F @repo/flappy-bird...",
    "dev:pacman": "turbo watch dev -F @repo/pacman...",
    "dev:tetris": "turbo watch dev -F @repo/tetris...",
    "dev:astroid": "turbo watch dev -F @repo/astroid...",
    "dev:pong": "turbo watch dev -F @repo/pong...",
    "dev:cli": "turbo watch dev -F vibedgames...",
    "lint": "oxlint --report-unused-disable-directives",
    "r2:lifecycle": "pnpm -C apps/web exec wrangler r2 bucket lifecycle set vibedgames-games --file ./infra/r2/vibedgames-games.lifecycle.json --force",
    "typecheck": "turbo run typecheck",
    "format": "oxfmt",
    "lint:fix": "oxlint --fix",
    "format:fix": "oxfmt --write"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.8",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "@tailwindcss/oxide",
      "core-js",
      "esbuild",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "react-hook-form": "^7.72.1"
    }
  }
}
